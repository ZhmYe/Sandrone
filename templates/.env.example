# Sandrone agent/reviewer model routing
# 留空表示沿用环境变量 / codex config 的默认值。
#
# review 修复轮数由 CLI 调度控制:
# decomposition/plan review 默认 5 次，code/integration review 默认 20 次。
# 单次运行可用 `sandrone tick --max-attempts <n>` 或
# `sandrone advance --request_id <REQ> --max-attempts <n>` 覆盖。

# 通用回退（agent/reviewer）：
# SANDRONE_MODEL=gpt-5.5
# SANDRONE_AGENT_REASONING_EFFORT=
# SANDRONE_REVIEWER_MODEL=
# SANDRONE_REVIEWER_REASONING_EFFORT=

# Agent 分阶段模型
# SANDRONE_DECOMPOSITION_AGENT_MODEL=gpt-5.5
# SANDRONE_DECOMPOSITION_AGENT_REASONING_EFFORT=
# SANDRONE_PLAN_AGENT_MODEL=gpt-5.5
# SANDRONE_PLAN_AGENT_REASONING_EFFORT=
# SANDRONE_IMPLEMENTATION_AGENT_MODEL=gpt-5.5
# SANDRONE_IMPLEMENTATION_AGENT_REASONING_EFFORT=
# SANDRONE_REBASE_AGENT_MODEL=gpt-5.5
# SANDRONE_REBASE_AGENT_REASONING_EFFORT=

# Agent 通用（用于缺省阶段）
# SANDRONE_AGENT_MODEL=gpt-5.5
# SANDRONE_AGENT_REASONING_EFFORT=

# Reviewer 分类型模型
# SANDRONE_PLAN_REVIEWER_MODEL=gpt-5.5
# SANDRONE_PLAN_REVIEWER_REASONING_EFFORT=
# SANDRONE_TEST_REVIEWER_MODEL=gpt-5.5
# SANDRONE_TEST_REVIEWER_REASONING_EFFORT=
# SANDRONE_DESIGN_REVIEWER_MODEL=gpt-5.5
# SANDRONE_DESIGN_REVIEWER_REASONING_EFFORT=
# SANDRONE_INTEGRATION_REVIEWER_MODEL=gpt-5.5
# SANDRONE_INTEGRATION_REVIEWER_REASONING_EFFORT=
# SANDRONE_DECOMPOSITION_REVIEWER_MODEL=
# SANDRONE_DECOMPOSITION_REVIEWER_REASONING_EFFORT=

# 连接器与运行时（可选）
# SANDRONE_CODEX_BIN=/absolute/path/to/codex
# SANDRONE_CODEX_APP=/Applications/Codex.app
# SANDRONE_ENV_FILE=/absolute/path/to/workspace/.env
