# Sandrone agent/reviewer model routing
# 留空表示沿用环境变量 / codex config 的默认值。
#
# review 修复轮数由 CLI 调度控制:
# decomposition/plan review 默认 5 次，code/integration review 默认 20 次。
# 单次运行可用 `sandrone tick --max-attempts <n>` 或
# `sandrone advance --request_id <REQ> --max-attempts <n>` 覆盖。

# 通用回退（agent/reviewer）：
# SANDRONE_MODEL=gpt-5.5
# SANDRONE_AGENT_REASONING_EFFORT=
# SANDRONE_REVIEWER_MODEL=
# SANDRONE_REVIEWER_REASONING_EFFORT=

# Agent backend
# 支持值:
# - codex-cli: 默认，调用 Codex CLI，有文件/命令能力。
# - codex-api: 调用 Codex CLI，但让 Codex 使用 LLM_API_KEY/LLM_BASE_URL/SANDRONE_*_MODEL。
# - claude-code: 保留值，当前默认脚本尚未实现，会阻塞并提示切换 backend。
# SANDRONE_AGENT_BACKEND=codex-cli
# SANDRONE_AGENT_BACKEND=codex-api
# SANDRONE_AGENT_BACKEND=claude-code
# SANDRONE_DECOMPOSITION_AGENT_BACKEND=
# SANDRONE_PLAN_AGENT_BACKEND=
# SANDRONE_IMPLEMENTATION_AGENT_BACKEND=

# Agent 分阶段模型
# SANDRONE_DECOMPOSITION_AGENT_MODEL=gpt-5.5
# SANDRONE_DECOMPOSITION_AGENT_REASONING_EFFORT=
# SANDRONE_PLAN_AGENT_MODEL=gpt-5.5
# SANDRONE_PLAN_AGENT_REASONING_EFFORT=
# SANDRONE_IMPLEMENTATION_AGENT_MODEL=gpt-5.5
# SANDRONE_IMPLEMENTATION_AGENT_REASONING_EFFORT=
# SANDRONE_REBASE_AGENT_MODEL=gpt-5.5
# SANDRONE_REBASE_AGENT_REASONING_EFFORT=

# Agent 通用（用于缺省阶段）
# SANDRONE_AGENT_MODEL=gpt-5.5
# SANDRONE_AGENT_REASONING_EFFORT=

# Reviewer 分类型模型
# SANDRONE_PLAN_REVIEWER_MODEL=gpt-5.5
# SANDRONE_PLAN_REVIEWER_REASONING_EFFORT=
# SANDRONE_TEST_REVIEWER_MODEL=gpt-5.5
# SANDRONE_TEST_REVIEWER_REASONING_EFFORT=
# SANDRONE_DESIGN_REVIEWER_MODEL=gpt-5.5
# SANDRONE_DESIGN_REVIEWER_REASONING_EFFORT=
# SANDRONE_INTEGRATION_REVIEWER_MODEL=gpt-5.5
# SANDRONE_INTEGRATION_REVIEWER_REASONING_EFFORT=
# SANDRONE_DECOMPOSITION_REVIEWER_MODEL=
# SANDRONE_DECOMPOSITION_REVIEWER_REASONING_EFFORT=

# Reviewer backend
# 支持值:
# - codex-cli: 默认，调用 Codex CLI，并使用 Codex 登录态。
# - codex-api: 调用 Codex CLI，但让 Codex 使用 LLM_API_KEY/LLM_BASE_URL/SANDRONE_*_MODEL。
# - claude-code: 保留值，当前默认脚本尚未实现，会阻塞并提示切换 backend。
# API key 只放本地 .env 或 shell 环境，绝不提交。
# SANDRONE_REVIEW_BACKEND=codex-cli
# SANDRONE_REVIEW_BACKEND=codex-api
# SANDRONE_REVIEW_BACKEND=claude-code
# SANDRONE_REVIEWER_BACKEND=
# SANDRONE_DECOMPOSITION_REVIEWER_BACKEND=
# SANDRONE_PLAN_REVIEWER_BACKEND=
# SANDRONE_TEST_REVIEWER_BACKEND=
# SANDRONE_DESIGN_REVIEWER_BACKEND=
# SANDRONE_INTEGRATION_REVIEWER_BACKEND=
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# SANDRONE_CODEX_MODEL_PROVIDER=sandrone-api
# SANDRONE_CODEX_PROVIDER_NAME=Sandrone API
# SANDRONE_CODEX_WIRE_API=responses
# SANDRONE_CODEX_MODEL_CATALOG_JSON=
# SANDRONE_REVIEW_TIMEOUT_SECONDS=1800

# 连接器与运行时（可选）
# 默认不自动 merge。开启后 `sandrone tick` 每轮最多处理一个 wait-finish PR，
# 且仍要求 pr-status=safe、队列 ready、change-doc gate 已通过。
# SANDRONE_AUTO_MERGE=0
# SANDRONE_CODEX_BIN=/absolute/path/to/codex
# SANDRONE_CODEX_APP=/Applications/Codex.app
# SANDRONE_ENV_FILE=/absolute/path/to/workspace/.env
# 默认 agent 不继承用户个人 Codex config、skill 和插件，避免自动化子会话读入大量无关上下文。
# Sandrone 会把当前 phase 需要的 prompt、CodeGraph/Obsidian 路径和脚本能力直接传给子 agent。
# 只有确实需要子 agent 继承个人插件/skill 时才设为 0。
# SANDRONE_AGENT_IGNORE_USER_CONFIG=1
